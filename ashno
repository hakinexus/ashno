#!/bin/bash
# ==============================================================================
#
# Ashno: The Professional Termux Toolkit Installer
#
# Version:      1.9.5
# Author:       hakinexus
# Description:  The definitive installer framework with a professional UI,
#               automatic dependency resolution, and robust error handling.
#
# ==============================================================================

# --- Globals and Configuration ---
readonly SCRIPT_NAME="Ashno"
readonly SCRIPT_PATH=$(readlink -f "$0")
readonly SCRIPT_DIR=$(dirname "$SCRIPT_PATH")
readonly SRC_DIR="$SCRIPT_DIR/src"
ORIGINAL_ARGS=("$@")

# --- Source Modules ---
source "$SRC_DIR/config.sh"
source "$SRC_DIR/utils.sh"
source "$SRC_DIR/updater.sh"
source "$SRC_DIR/engine.sh"
source "$SRC_DIR/menus.sh"
source "$SRC_DIR/configure.sh"

# ==============================================================================
# SECTION: EXECUTION ENTRYPOINT
# ==============================================================================
if [ ! -d "$PROFILES_DIR" ]; then echo -e "${RED}Fatal Error: '${PROFILES_DIR}/' not found.${NC}"; exit 1; fi

# --- Non-Interactive Mode ---
if [ $# -gt 0 ]; then
    profile_arg=""; action_arg=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help) print_help_menu; exit 0;;
            -u|--update) handle_updates "manual"; exit 0;;
            -c|--configure) configure_menu; exit 0;;
            --profile)
                if [ -z "${2:-}" ] || [[ "$2" == --* ]]; then
                    echo -e "${RED}Error: --profile requires a value.${NC}"; exit 1
                fi
                profile_arg="$2"; shift 2;;
            --all|--pkg|--npm|--pip) action_arg="$1"; shift 1;;
            *) echo -e "${RED}Invalid argument: $1${NC}\nUse 'ashno --help'."; exit 1;;
        esac
    done
    
    if [ -z "$profile_arg" ] || [ -z "$action_arg" ] || [ ! -d "${PROFILES_DIR}/${profile_arg}" ]; then 
        echo -e "${RED}Error: Valid --profile and action required.${NC}"; exit 1
    fi
    
    SELECTED_PROFILE="$profile_arg"
    pre_flight_checks; handle_updates "auto"

    if [ "$action_arg" = "--all" ] || [ "$action_arg" = "--pkg" ]; then update_termux; install_pkg; fi
    if [ "$action_arg" = "--all" ] || [ "$action_arg" = "--npm" ]; then install_npm; fi
    if [ "$action_arg" = "--all" ] || [ "$action_arg" = "--pip" ]; then install_pip; fi
    
    print_summary_report; exit 0
fi

# --- Interactive Mode ---
clear; handle_updates "auto"; profile_selection_menu
pre_flight_checks
while true; do
    main_menu
    case $main_choice in
        1) update_termux; install_pkg; install_npm; install_pip;;
        2) update_termux; install_pkg;;
        3) install_npm;;
        4) install_pip;;
        5) configure_menu; continue;;
        6) profile_selection_menu; continue;;
        7) echo -e "\nExiting Ashno."; exit 0;;
        *) echo -e "\n${RED}Invalid choice.${NC}"; sleep 1; continue;;
    esac
    print_summary_report
    offer_configuration
    if command -v gum &>/dev/null; then
        gum confirm "Return to main menu?" && continue || { echo -e "\nExiting Ashno."; exit 0; }
    else
        echo; read -n 1 -s -r -p "Press any key to return to the main menu..."
    fi
    SUCCESS_LIST=(); FAILURE_LIST=(); SKIPPED_LIST=();
done
